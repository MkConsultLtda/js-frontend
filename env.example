# Copie para .env.local (não versionar segredos reais)
# Ver: docs/operacao/variaveis-ambiente-local-producao.md

# --- LOCAL (desenvolvimento) ---
NODE_ENV=development
# Base da API Spring (deve incluir /v1 se for o prefixo do AuthController)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/v1
BACKEND_API_URL=http://localhost:8080/v1

# --- PRODUÇÃO (ex.: Vercel — preencher no painel) ---
# NODE_ENV=production
# NEXT_PUBLIC_API_BASE_URL=https://api.seu-dominio.com/v1
# BACKEND_API_URL=https://api.seu-dominio.com/v1
# OBRIGATÓRIO em prod: mesmo host/prefixo /v1 usado pelo Spring; mesma URL para route handlers (/api/backend).
